<Window
    Title="arneselectronics"
    d:DesignHeight=""
    d:DesignWidth=""
    mc:Ignorable="d"
    x:Class="arneselectronics.MainView"
    x:DataType="vm:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:arneselectronics.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext> 
    <!--  This lets us see the preview of our program  -->


    <StackPanel>
        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
            <Button Command="{Binding GoToHomeCommand}" Grid.Column="0">Frontpage</Button>
            <Button Command="{Binding GoToHardwareCommand}" Grid.Column="1">Hardware</Button>
            <Button Command="{Binding GoToDesktopCommand}" Grid.Column="2">Desktop</Button>
            <Button Command="{Binding GoToAccessoriesCommand}" Grid.Column="3">Accesories</Button>
            <Button Command="{Binding GoToResourceCommand}" Grid.Column="4">Ressources</Button>
            <Button Command="{Binding GoToLaptopCommand}" Grid.Column="5">Laptop</Button>
            <Button Command="{Binding GoToProductDetailPageCommand}" Grid.Column="6">ProductDetailPage</Button>
        </Grid>
        <Grid ColumnDefinitions="*,*,Auto" RowDefinitions="Auto, Auto">
            <!--  Add Image control for Logo  -->
            <Image
                Grid.Column="0"
                Height="100"
                HorizontalAlignment="Left"
                Margin="10"
                Width="200"
                x:Name="LogoImage" />

            <!--  Cart logo on the right  -->
            <Image
                Grid.Column="1"
                Height="60"
                HorizontalAlignment="Right"
                Margin="10"
                Width="50"
                x:Name="CartLogo" />

        </Grid>
        <!--  TextBlock for the total in the middle column  -->

        <StackPanel
            Grid.Column="2"
            HorizontalAlignment="Right"
            Margin="10"
            VerticalAlignment="Center">
            <TextBlock
                FontSize="14"
                Height="15"
                Name="Total"
                Text="Total:" />
            <TextBlock
                Height="15"
                Name="Quantity"
                Text="Antal varer:" />
        </StackPanel>

        <ContentControl Content="{Binding CurrentPage}" />
    </StackPanel>

</Window>

